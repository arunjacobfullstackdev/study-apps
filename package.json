{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "docker:api:up": "docker compose -f compose.api.yaml up --build -d",
    "docker:api:down": "docker compose -f compose.api.yaml down",
    "docker:docs:up": "docker compose -f compose.docs.yaml up --build -d",
    "docker:docs:down": "docker compose -f compose.docs.yaml down",
    "docker:web:up": "docker compose -f compose.web.yaml up --build -d web",
    "docker:web:down": "docker compose -f compose.web.yaml stop api && docker compose -f compose.web.yaml stop web && docker compose -f compose.web.yaml down --remove-orphans"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --cache --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
